# MoleKVM Environment Configuration
# Copy to .env and configure for your environment
# Compatible with: Docker, Plesk, Local PHP Server

# ═══════════════════════════════════════════════════════════
# CORE APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════

SITE_NAME="MoleKVM"
SITE_URL=https://molekvm.com
SITE_DEBUG=false

# ═══════════════════════════════════════════════════════════
# PRODUCT PRICING & OFFERS
# Positioning: €49 (vs NanoKVM €40-50) - Best value open-source KVM
# ═══════════════════════════════════════════════════════════

# Base device price - competitive with NanoKVM (€40-50 range)
PRODUCT_PRICE_BASE=49
PRODUCT_PRICE_CURRENCY=EUR

# Early bird / Kickstarter pricing
PRODUCT_PRICE_EARLY_BIRD=39
PRODUCT_PRICE_KS_BACKER=49
PRODUCT_PRICE_KS_EARLY_MOLE=39
PRODUCT_PRICE_KS_IT_PRO_PACK=149
PRODUCT_PRICE_KS_MSP_FLEET=449
PRODUCT_PRICE_KS_DATA_CENTER=1999

# Volume/Fleet pricing (per device)
PRODUCT_PRICE_FLEET_10=45
PRODUCT_PRICE_FLEET_50=42
PRODUCT_PRICE_FLEET_100=39
PRODUCT_PRICE_FLEET_500=35

# ═══════════════════════════════════════════════════════════
# SUBSCRIPTION TIERS - LLM / AI Services
# Local LLM = Free | Cloud LLM Proxy = Paid subscription
# ═══════════════════════════════════════════════════════════

# Subscription tiers (monthly pricing in EUR)
SUB_TIER_LOCAL_NAME="Local LLM - Free Forever"
SUB_TIER_LOCAL_PRICE=0
SUB_TIER_LOCAL_FEATURES="local_ai,manual_control,community_support"

SUB_TIER_CLOUD_NAME="Cloud LLM Proxy"
SUB_TIER_CLOUD_PRICE=4.99
SUB_TIER_CLOUD_FEATURES="cloud_llm_proxy,gpt4o_access,5k_requests_month,priority_support"

SUB_TIER_PRO_NAME="AI Pro"
SUB_TIER_PRO_PRICE=9.99
SUB_TIER_PRO_FEATURES="unlimited_llm,gpt4o_claude,61_repair_plans,api_access,priority_support"

SUB_TIER_ENTERPRISE_NAME="Enterprise AI"
SUB_TIER_ENTERPRISE_PRICE=29.99
SUB_TIER_ENTERPRISE_FEATURES="dedicated_llm,custom_models,sla,on_premise_option,team_management"

# Annual discount percentage
SUB_ANNUAL_DISCOUNT=20

# ═══════════════════════════════════════════════════════════
# LOCAL LLM CONFIGURATION
# For self-hosted AI (Ollama, llama.cpp, etc.)
# ═══════════════════════════════════════════════════════════

LOCAL_LLM_ENABLED=true
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_HOST=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_FALLBACK_MODEL=mistral
LOCAL_LLM_VISION_MODEL=llava
LOCAL_LLM_MAX_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0.7

# Alternative: llama.cpp server
# LOCAL_LLM_PROVIDER=llamacpp
# LOCAL_LLM_HOST=http://localhost:8080
# LOCAL_LLM_MODEL_PATH=/models/llama-3.2-3b-q4_k_m.gguf

# ═══════════════════════════════════════════════════════════
# CLOUD LLM PROXY CONFIGURATION
# Used when local LLM is disabled or for advanced models
# ═══════════════════════════════════════════════════════════

CLOUD_LLM_PROVIDER=openai
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=gpt-4o
CLOUD_LLM_VISION_MODEL=gpt-4o
CLOUD_LLM_MAX_TOKENS=4096
CLOUD_LLM_TEMPERATURE=0.5

# Alternative providers
CLOUD_LLM_ALTERNATIVE_PROVIDER=anthropic
CLOUD_LLM_ALTERNATIVE_API_KEY=
CLOUD_LLM_ALTERNATIVE_MODEL=claude-3-5-sonnet-20241022

# Proxy service settings
LLM_PROXY_CACHE_ENABLED=true
LLM_PROXY_CACHE_TTL=3600
LLM_PROXY_RATE_LIMIT_PER_MIN=60

# ═══════════════════════════════════════════════════════════
# COMPETITOR POSITIONING
# Marketing copy variables
# ═══════════════════════════════════════════════════════════

COMPETITOR_NANOKVM_PRICE=40
COMPETITOR_NANOKVM_PRICE_MAX=50
COMPETITOR_JETKVM_PRICE=115
COMPETITOR_JETKVM_PRICE_MAX=140
COMPETITOR_PIKVM_PRICE=349

VALUE_PROP_PRICE_SLOGAN="€49 - Cheaper than NanoKVM, more features than PiKVM"
VALUE_PROP_OPENSOURCE="100% Open Source - Apache 2.0 License"
VALUE_PROP_NO_HIDDENS="No hidden microphones, no hardcoded passwords"
VALUE_PROP_EU_MADE="Designed & Assembled in EU"

# ═══════════════════════════════════════════════════════════
# OPEN SOURCE FEATURES
# ═══════════════════════════════════════════════════════════

OPENSOURCE_LICENSE=Apache-2.0
OPENSOURCE_GITHUB_URL=https://github.com/tom-sapletta-com/him
OPENSOURCE_DOCS_URL=https://docs.molekvm.com
OPENSOURCE_FIRMWARE_REPO=https://github.com/tom-sapletta-com/molekvm-firmware
OPENSOURCE_GUI_REPO=https://github.com/tom-sapletta-com/molekvm-gui

# Feature comparison flags
FEATURE_OPENSOURCE_FIRMWARE=true
FEATURE_OPENSOURCE_HARDWARE=true
FEATURE_OPENSOURCE_GUI=true
FEATURE_AUDITABLE_CODE=true
FEATURE_SELF_HOSTABLE=true

# ═══════════════════════════════════════════════════════════
# STRIPE PAYMENT PROCESSING
# Get keys from: https://dashboard.stripe.com/apikeys
# ═══════════════════════════════════════════════════════════

STRIPE_PK=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Device pricing (one-time purchases)
STRIPE_PRICE_DEVICE_BASE=price_XXXXX           # €49 one-time
STRIPE_PRICE_DEVICE_EARLY_BIRD=price_XXXXX     # €39 Kickstarter Early Mole
STRIPE_PRICE_DEVICE_IT_PRO_PACK=price_XXXXX    # €149 for 3 devices
STRIPE_PRICE_DEVICE_MSP_FLEET=price_XXXXX      # €449 for 10 devices
STRIPE_PRICE_DEVICE_DATA_CENTER=price_XXXXX    # €1999 for 50 devices

# Subscription tiers (monthly recurring)
STRIPE_PRICE_SUB_CLOUD_LLM=price_XXXXX         # €4.99/month - Cloud LLM Proxy
STRIPE_PRICE_SUB_AI_PRO=price_XXXXX            # €9.99/month - AI Pro unlimited
STRIPE_PRICE_SUB_ENTERPRISE=price_XXXXX        # €29.99/month - Enterprise AI

# Annual subscription (with discount)
STRIPE_PRICE_SUB_CLOUD_LLM_YEARLY=price_XXXXX  # €47.90/year (20% off)
STRIPE_PRICE_SUB_AI_PRO_YEARLY=price_XXXXX     # €95.90/year (20% off)

# Legacy price IDs (for reference/comparison)
STRIPE_PRICE_OLD_DEVICE=price_XXXXX            # Old €99 pricing (deprecated)

# ═══════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (SMTP)
# For Plesk: Use localhost with port 25 (no auth needed)
# For external: Use SendGrid, Mailgun, etc.
# ═══════════════════════════════════════════════════════════

SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@molekvm.com
SMTP_FROM_NAME="MoleKVM"

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=

# ═══════════════════════════════════════════════════════════
# DATABASE (PostgreSQL/MySQL)
# Used by server.js backend (if enabled)
# ═══════════════════════════════════════════════════════════

DB_HOST=localhost
DB_PORT=5432
DB_NAME=molekvm
DB_USER=molekvm
DB_PASSWORD=your_secure_password_here
DB_URL=postgresql://molekvm:${DB_PASSWORD}@localhost:5432/molekvm

# ═══════════════════════════════════════════════════════════
# AI / CLOUD API SETTINGS
# ═══════════════════════════════════════════════════════════

AI_API_KEY=
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════
# PLESK HOSTING SETTINGS
# These are automatically detected when running on Plesk
# ═══════════════════════════════════════════════════════════

# PLESK_DOMAIN=molekvm.com
# PLESK_HTTPDOCS=/var/www/vhosts/molekvm.com/httpdocs

# ═══════════════════════════════════════════════════════════
# DOCKER DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════

DOCKER_APACHE_PORT=8080
DOCKER_PLESK_PORT=8081
DOCKER_NGINX_PORT=8082

# ═══════════════════════════════════════════════════════════
# SECURITY SETTINGS
# ═══════════════════════════════════════════════════════════

# Session/Cookie settings
SESSION_LIFETIME=120
COOKIE_SECURE=true
COOKIE_HTTPONLY=true

# Admin contact
ADMIN_EMAIL=tom@sapletta.com

# ═══════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════

ENABLE_PREORDERS=true
ENABLE_STRIPE_CHECKOUT=true
ENABLE_KICKSTARTER_NOTIFY=true
ENABLE_CLOUD_API=false

