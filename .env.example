# MoleKVM Environment Variables
# Copy to .env and fill in your values

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_DEVICE=price_XXXXX        # €99 one-time
STRIPE_PRICE_PRO=price_XXXXX           # €99 one-time (device)
STRIPE_PRICE_FLEET=price_XXXXX         # €79 one-time (volume)
STRIPE_PRICE_SUB_PRO=price_XXXXX       # €9.99/month recurring

# Database
DB_PASSWORD=your_secure_password_here

# Email (optional - for order confirmations)
SENDGRID_API_KEY=

# Admin
ADMIN_EMAIL=info@softreck.com
